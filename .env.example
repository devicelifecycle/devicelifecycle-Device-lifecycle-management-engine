# ============================================================================
# DEVICE LIFECYCLE MANAGEMENT ENGINE - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.local and fill in the values

# ============================================================================
# SUPABASE
# ============================================================================
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# APP CONFIGURATION
# ============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Device Lifecycle Management Engine"

# ============================================================================
# AUTHENTICATION
# ============================================================================
# Session duration in seconds (default: 7 days)
AUTH_SESSION_DURATION=604800

# ============================================================================
# CRON JOBS
# ============================================================================
# Secret for authenticating cron job requests
CRON_SECRET=your-random-secret-here

# ============================================================================
# EMAIL (for notifications)
# ============================================================================
# Resend API key for sending emails
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@yourdomain.com

# ============================================================================
# STORAGE (for file uploads)
# ============================================================================
# Supabase Storage bucket name
STORAGE_BUCKET=attachments

# ============================================================================
# EXTERNAL SERVICES (optional)
# ============================================================================
# IMEI Check service API key
IMEI_CHECK_API_KEY=
IMEI_CHECK_API_URL=

# Shipping carrier APIs
FEDEX_API_KEY=
FEDEX_API_SECRET=
UPS_API_KEY=
USPS_API_KEY=

# ============================================================================
# DEVELOPMENT
# ============================================================================
# Enable debug logging
DEBUG=false

# ============================================================================
# ANALYTICS (optional)
# ============================================================================
NEXT_PUBLIC_ANALYTICS_ID=
