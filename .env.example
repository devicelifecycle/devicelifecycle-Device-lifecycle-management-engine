# ============================================================================
# DEVICE LIFECYCLE MANAGEMENT ENGINE - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.local and fill in the values

# ============================================================================
# SUPABASE
# ============================================================================
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# APP CONFIGURATION
# ============================================================================
# Base URL — used in email links (View Order, Reset Password). Set to your production URL for emails to work.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Device Lifecycle Management Engine"

# ============================================================================
# AUTHENTICATION
# ============================================================================
# Session duration in seconds (default: 7 days)
AUTH_SESSION_DURATION=604800

# ============================================================================
# CRON JOBS
# ============================================================================
# Secret for authenticating cron job requests
CRON_SECRET=your-random-secret-here

# Price scraper pipeline (Bell, Telus, GoRecell, UniverCell, Apple trade-in)
PRICE_SCRAPER_ENABLED=false
# UniverCell pilot implementation selector:
#   ts        -> current TypeScript scraper only (default)
#   scrapling -> isolated Python Scrapling worker only
#   dual      -> run both, log comparison, persist TypeScript result
SCRAPER_UNIVERCELL_IMPL=scrapling
# Bell pilot implementation selector:
#   ts        -> current TypeScript scraper only (default)
#   scrapling -> isolated Python Scrapling worker only
#   dual      -> run both, log comparison, persist TypeScript result
SCRAPER_BELL_IMPL=ts
# GoRecell pilot implementation selector:
#   ts        -> current TypeScript scraper only (default)
#   scrapling -> isolated Python Scrapling worker only
#   dual      -> run both, log comparison, persist TypeScript result
SCRAPER_GORECELL_IMPL=ts
# Apple Trade-In pilot implementation selector:
#   ts        -> current TypeScript scraper only (default)
#   scrapling -> isolated Python Scrapling worker only
#   dual      -> run both, log comparison, persist TypeScript result
SCRAPER_APPLE_IMPL=ts
# Telus pilot implementation selector:
#   ts        -> current TypeScript scraper only (default)
#   scrapling -> isolated Python Scrapling worker only
#   dual      -> run both, log comparison, persist TypeScript result
SCRAPER_TELUS_IMPL=ts
# Optional Python binary override for the Scrapling worker
# SCRAPLING_PYTHON_BIN=python3
# Optional worker timeout override in milliseconds
# SCRAPLING_WORKER_TIMEOUT_MS=180000
# Optional aggregate rollout validation timeout per provider step in milliseconds
# SCRAPLING_VALIDATION_TIMEOUT_MS=300000
# Optional dual burn-in timeout per provider step in milliseconds
# SCRAPLING_BURNIN_TIMEOUT_MS=300000
# Optional URL overrides (defaults shown):
# BELL_TRADE_IN_URL=https://www.bell.ca/Mobility/Trade-in-program
# BELL_PROXY_AUTH_URL=https://www.bell.ca/ajax/toolbox/CorsProxyAuthenticate
# BELL_TRADE_IN_BASE_ADDR=https://ws1-bell.sbeglobalcare.com/gc-ws-connect-1.9/rest/gcWsConnect/
# TELUS_TRADE_IN_URL=https://www.telus.com/en/mobility/trade-in-bring-it-back-returns
# TELUS_DEVICES_API_URL=https://www.telus.com/mobility/trade-in/backend/devices
# GORECELL_STORE_API=https://gorecell.ca/wp-json/wc/store/v1/products
# GORECELL_PRODUCT_BASE=https://gorecell.ca/product/
# APPLE_TRADE_IN_URL=https://www.apple.com/ca/shop/trade-in
# UNIVERCELL_ACTION_URL=https://univercell.ai/sell/details/mobile
# UNIVERCELL_ACTION_GET_DEVICE_TYPES=
# UNIVERCELL_ACTION_GET_MAKES_FOR_DEVICE_TYPE=
# UNIVERCELL_ACTION_GET_MODELS_FOR_MAKE_AND_TYPE=

# Data-driven pricing model training (from orders, IMEI, sales_history)
# Trains our own baselines to reduce third-party dependency
PRICING_TRAINING_ENABLED=false

# CSV competitor sync (alternative to scrapers)
# URL to CSV with columns: device_id, storage, competitor_name, trade_in_price, sell_price
COMPETITOR_SYNC_ENABLED=false
COMPETITOR_CSV_URL=

# ============================================================================
# EMAIL (for notifications, welcome, forgot-password)
# ============================================================================
# Option A — Gmail SMTP (easiest; no domain verification; sends to anyone)
# 1. Enable 2-Step Verification at myaccount.google.com/security
# 2. Create App Password: Google Account → Security → App passwords → Mail
# 3. Add below:
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
# Optional: GMAIL_FROM_EMAIL=DLM Engine <your-email@gmail.com>
#
# Option B — Resend (requires domain verification to send to external emails)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com
#
# For Login ID users (@login.local): set notification_email in Profile or Admin → Users
# so order notifications and forgot-password emails are delivered.
#
# Option C — Twilio SMS (reliable delivery to any carrier)
# 1. Sign up at twilio.com (free trial gives $15 credit ~1900 SMS)
# 2. Get Account SID + Auth Token from console.twilio.com
# 3. Buy a phone number ($1/month) or use the trial number
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================================================
# STORAGE (for file uploads)
# ============================================================================
# Supabase Storage bucket name
STORAGE_BUCKET=attachments

# ============================================================================
# EXTERNAL SERVICES (optional)
# ============================================================================
# IMEI Check service API key
IMEI_CHECK_API_KEY=
IMEI_CHECK_API_URL=

# Shipping carrier APIs (optional, for direct carrier integration)
FEDEX_API_KEY=
FEDEX_API_SECRET=
UPS_API_KEY=
USPS_API_KEY=

# Stallion Express (primary shipping provider for Canada)
# Get your API token from: Account Settings > API Token in Stallion dashboard
STALLION_API_TOKEN=
# Production: https://ship.stallionexpress.ca/api/v4
# Sandbox:    https://sandbox.stallionexpress.ca/api/v4
STALLION_API_BASE_URL=https://ship.stallionexpress.ca/api/v4
# Optional: Your store ID if you have multiple stores
STALLION_STORE_ID=

# ============================================================================
# DEVELOPMENT
# ============================================================================
# Enable debug logging
DEBUG=false

# ============================================================================
# ANALYTICS (optional)
# ============================================================================
NEXT_PUBLIC_ANALYTICS_ID=
